<Window x:Class="SwanCode.Core.Views.Dialogs.CommandConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource str_ExecuteCommand}"
        Width="520" Height="280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource PrimaryBackground}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{DynamicResource str_CommandDescription}" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" x:Name="DescriptionText" TextWrapping="Wrap" Margin="0,0,0,12"/>

        <TextBlock Grid.Row="2" Text="{DynamicResource str_ExecuteCommand}" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBox Grid.Row="3" x:Name="CommandText" IsReadOnly="True"
                 FontFamily="Consolas" FontSize="12"
                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                 Background="{DynamicResource SecondaryBackground}"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{DynamicResource str_AutoExecuteAll}" Width="180" Margin="0,0,8,0" Click="AutoAll_Click"/>
            <Button Content="{DynamicResource str_ExecuteCommand}" Width="110" Margin="0,0,8,0" Click="Execute_Click"/>
            <Button Content="{DynamicResource str_SkipCommand}" Width="110" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
