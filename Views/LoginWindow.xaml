<Window x:Class="SwanCode.Core.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login"
        Height="320" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource PrimaryBackground}">
    <Grid Margin="30,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- User-ключ -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="{DynamicResource str_UserKeyLabel}"
                       Foreground="{DynamicResource PrimaryForeground}"
                       Margin="0,0,0,4"/>
            <PasswordBox x:Name="KeyBox"
                         Padding="6,4"
                         FontSize="14"
                         FontFamily="Consolas"
                         KeyDown="KeyBox_KeyDown"/>
        </StackPanel>

        <!-- Подсказка -->
        <TextBlock Grid.Row="2"
                   Text="{DynamicResource str_UserKeyHint}"
                   Foreground="{DynamicResource SecondaryForeground}"
                   FontSize="11"
                   TextWrapping="Wrap"/>

        <!-- Кнопка -->
        <Button Grid.Row="4"
                x:Name="LoginButton"
                Content="{DynamicResource str_LoginButton}"
                Height="36"
                FontSize="14"
                Click="LoginButton_Click"
                IsDefault="True"/>

        <!-- Подсказка «Нет ключа?» -->
        <TextBlock Grid.Row="6"
                   Text="{DynamicResource str_NoKeyHint}"
                   Foreground="{DynamicResource SecondaryForeground}"
                   FontSize="11"
                   TextWrapping="Wrap"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"/>

        <!-- Ошибка -->
        <TextBlock Grid.Row="8"
                   x:Name="ErrorText"
                   Foreground="Red"
                   TextWrapping="Wrap"
                   FontSize="12"
                   Visibility="Collapsed"/>

        <!-- Статус -->
        <TextBlock Grid.Row="10"
                   x:Name="StatusText"
                   Foreground="{DynamicResource SecondaryForeground}"
                   FontSize="11"
                   HorizontalAlignment="Center"
                   Visibility="Collapsed"/>
    </Grid>
</Window>
