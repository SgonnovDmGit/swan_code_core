<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Auth / LoginWindow (Phase 5a: user-key + X-Product-Key). Заголовок окна — из IProductBranding.DisplayName, не из ресурса. -->
    <sys:String x:Key="str_UserKeyLabel">User-ключ</sys:String>
    <sys:String x:Key="str_UserKeyHint">Ключ выдаёт администратор.</sys:String>
    <sys:String x:Key="str_LoginButton">Войти</sys:String>
    <sys:String x:Key="str_LoggingIn">Проверяю ключ...</sys:String>
    <sys:String x:Key="str_LoginError">Ошибка входа</sys:String>
    <sys:String x:Key="str_InvalidKeyFormat">Введите user-ключ</sys:String>
    <sys:String x:Key="str_InvalidUserKey">Неверный или отозванный user-ключ</sys:String>
    <sys:String x:Key="str_UserDeleted">Аккаунт удалён. Обратитесь к администратору.</sys:String>
    <sys:String x:Key="str_NoProductKey">Не настроен product-ключ сборки (APP_PRODUCT_KEY в .env)</sys:String>
    <sys:String x:Key="str_TokenExpired">User-ключ невалиден. Войдите заново.</sys:String>
    <sys:String x:Key="str_InsufficientBalance">Недостаточно средств на балансе</sys:String>
    <sys:String x:Key="str_ChangeKeyConfirm">Сменить user-ключ?</sys:String>
    <sys:String x:Key="str_NotConfigured">Не настроен</sys:String>
    <sys:String x:Key="str_BalanceCoins">монет</sys:String>
    <sys:String x:Key="str_NoKeyHint">Нет ключа? Свяжитесь с администратором проекта.</sys:String>

    <!-- Диалоги ядра: ErrorExplainDialog -->
    <sys:String x:Key="str_ErrorExplainTitle">Объяснить ошибку</sys:String>
    <sys:String x:Key="str_ErrorCode">Код с ошибкой</sys:String>
    <sys:String x:Key="str_ErrorText">Текст ошибки</sys:String>
    <sys:String x:Key="str_ModulePath">Путь к модулю</sys:String>

    <!-- Диалоги ядра: CommandConfirmDialog -->
    <sys:String x:Key="str_CommandDescription">Описание команды</sys:String>
    <sys:String x:Key="str_ExecuteCommand">Выполнить</sys:String>
    <sys:String x:Key="str_SkipCommand">Пропустить</sys:String>
    <sys:String x:Key="str_AutoExecuteAll">Всегда выполнять</sys:String>

    <!-- Общие кнопки диалогов -->
    <sys:String x:Key="str_Send">Отправить</sys:String>
    <sys:String x:Key="str_Cancel">Отмена</sys:String>

    <!-- Chat-каркас (T-000046, v0.11.2). Общие ключи для 1С и Universal чатов. -->

    <!-- Composer -->
    <!-- Подсказка учит обращению с полем: Enter отправляет, хотя поле многострочное.
         «Опишите задачу» уместно только в начале — в идущем диалоге задачу уже описали. -->
    <sys:String x:Key="str_Chat_InputPlaceholder">Опишите задачу · Enter — отправить, Shift+Enter — новая строка</sys:String>
    <sys:String x:Key="str_Chat_InputPlaceholderOngoing">Enter — отправить, Shift+Enter — новая строка</sys:String>
    <sys:String x:Key="str_Chat_InputHint">Enter — отправить, Shift+Enter — перенос</sys:String>
    <sys:String x:Key="str_Chat_SendButton">Отправить</sys:String>
    <sys:String x:Key="str_Chat_NewChat">Новый диалог</sys:String>
    <sys:String x:Key="str_Chat_Interrupt">Прервать</sys:String>

    <!-- Assistant states -->
    <sys:String x:Key="str_Chat_Streaming">стрим</sys:String>
    <sys:String x:Key="str_Chat_Interrupted">прервано</sys:String>
    <sys:String x:Key="str_Chat_Thinking">думаю…</sys:String>

    <!-- Reasoning block -->
    <sys:String x:Key="str_Chat_Reasoning">Размышления</sys:String>

    <!-- Tool card -->
    <sys:String x:Key="str_Chat_ToolStatusSuccess">success</sys:String>
    <sys:String x:Key="str_Chat_ToolStatusFailure">failure</sys:String>
    <sys:String x:Key="str_Chat_ToolStatusPending">в работе</sys:String>

    <!-- Message actions -->
    <sys:String x:Key="str_Chat_ActionCopy">Копировать</sys:String>
    <sys:String x:Key="str_Chat_ActionQuote">Цитировать</sys:String>
    <sys:String x:Key="str_Chat_ActionRetry">Повторить</sys:String>
    <sys:String x:Key="str_Chat_ActionInfo">Инфо про ход</sys:String>

    <!-- Info popup — key/value в столбик -->
    <sys:String x:Key="str_Chat_InfoTitle">инфо про ход</sys:String>
    <sys:String x:Key="str_Chat_InfoModel">модель</sys:String>
    <sys:String x:Key="str_Chat_InfoProvider">провайдер</sys:String>
    <sys:String x:Key="str_Chat_InfoEffort">effort</sys:String>
    <sys:String x:Key="str_Chat_InfoReasoning">размышления</sys:String>
    <sys:String x:Key="str_Chat_InfoPromptTokens">prompt</sys:String>
    <sys:String x:Key="str_Chat_InfoCompletionTokens">completion</sys:String>
    <sys:String x:Key="str_Chat_InfoTotalTokens">всего</sys:String>
    <sys:String x:Key="str_Chat_InfoCost">стоимость</sys:String>
    <sys:String x:Key="str_Chat_InfoCostRub">в рублях</sys:String>
    <sys:String x:Key="str_Chat_InfoCostUsd">в usd</sys:String>
    <sys:String x:Key="str_Chat_InfoTimeFirstChunk">1-й chunk</sys:String>
    <sys:String x:Key="str_Chat_InfoTimeTotal">всего</sys:String>
    <sys:String x:Key="str_Chat_InfoMessageId">id хода</sys:String>
    <sys:String x:Key="str_Chat_InfoTime">время</sys:String>

    <!-- Код-блок в ответе AI (T-000096) -->
    <sys:String x:Key="str_Chat_CopyCode">Копировать</sys:String>
    <sys:String x:Key="str_Chat_CopyCodeHint">Скопировать фрагмент в буфер обмена</sys:String>
    <sys:String x:Key="str_Chat_ToSandbox">→ в песочницу</sys:String>
    <sys:String x:Key="str_Chat_ToSandboxHint">Положить фрагмент в песочницу — оттуда можно применить в окно конфигуратора</sys:String>

    <!-- Компактизация контекста (ANNOUNCE-005) -->
    <sys:String x:Key="str_Chat_ContextCompacted">Контекст сжат — дальше модель помнит начало диалога по этой сводке</sys:String>

    <!-- Доска задач (T-000080..T-000082, REQ-021) -->
    <sys:String x:Key="str_TaskBoard_Title">Доска задач</sys:String>
    <sys:String x:Key="str_TaskBoard_Pending">ожидает</sys:String>
    <sys:String x:Key="str_TaskBoard_InProgress">в работе</sys:String>
    <sys:String x:Key="str_TaskBoard_Done">выполнено</sys:String>
    <sys:String x:Key="str_TaskBoard_Blocked">блокировано</sys:String>
    <sys:String x:Key="str_TaskBoard_Cancelled">отменено</sys:String>
    <sys:String x:Key="str_TaskBoard_Toggle">Свернуть / развернуть доску задач</sys:String>
    <sys:String x:Key="str_TaskBoard_UserChecked">Отметил выполненной задачу «{0}».</sys:String>
    <sys:String x:Key="str_TaskBoard_UserUnchecked">Снял отметку выполнения с задачи «{0}».</sys:String>
    <sys:String x:Key="str_Tool_task_board_update">Доска задач</sys:String>
    <sys:String x:Key="str_TaskBoard_Add">+ Задача</sys:String>
    <sys:String x:Key="str_TaskBoard_AddHint">Добавить задачу вручную</sys:String>
    <sys:String x:Key="str_TaskBoard_NewTask">Новая задача</sys:String>
    <sys:String x:Key="str_TaskBoard_Empty">Задач нет. Добавьте вручную или попросите AI составить план.</sys:String>
    <sys:String x:Key="str_TaskBoard_CycleHint">Сменить статус: ожидает → в работе → выполнено</sys:String>
    <sys:String x:Key="str_TaskBoard_RemoveHint">Удалить задачу</sys:String>
    <sys:String x:Key="str_TaskBoard_CurrentHint">Текущая задача — её номер трекера идёт в маркеры кода</sys:String>
    <sys:String x:Key="str_TaskBoard_OurIdHint">Наш номер задачи в этом диалоге</sys:String>
    <sys:String x:Key="str_TaskBoard_TrackerHint">Номер во внешнем трекере (Jira и т.п.) — подставляется в маркер вместо {task}</sys:String>
    <sys:String x:Key="str_TaskBoard_UserDoneHint">Отметка пользователя: проверено и принято</sys:String>
    <sys:String x:Key="str_TaskBoard_DescriptionHint">Описание</sys:String>
    <sys:String x:Key="str_TaskBoard_TrackerPlaceholder">напр. JIRA-902</sys:String>
    <sys:String x:Key="str_TaskBoard_ColTask">ЗАДАЧА И ОПИСАНИЕ</sys:String>
    <sys:String x:Key="str_TaskBoard_ColOurId">НАШ №</sys:String>
    <sys:String x:Key="str_TaskBoard_ColTracker">ТРЕКЕР</sys:String>
    <sys:String x:Key="str_TaskBoard_ColUser">ПРИНЯЛ</sys:String>
    <sys:String x:Key="str_TaskBoard_ColStatus">СТАТУС ИИ</sys:String>
    <sys:String x:Key="str_TaskBoard_ModeCurrent">текущая</sys:String>
    <sys:String x:Key="str_TaskBoard_ModeThree">3</sys:String>
    <sys:String x:Key="str_TaskBoard_ModeAll">все</sys:String>
    <sys:String x:Key="str_TaskBoard_DragHint">Тянуть — менять порядок задач</sys:String>
    <sys:String x:Key="str_TaskBoard_SearchPlaceholder">Поиск по имени, описанию, трекеру…</sys:String>
    <sys:String x:Key="str_TaskBoard_SortManual">Сортировка: вручную</sys:String>
    <sys:String x:Key="str_TaskBoard_SortStatus">Сортировка: по статусу</sys:String>
    <sys:String x:Key="str_TaskBoard_SortTracker">Сортировка: по трекеру</sys:String>
    <sys:String x:Key="str_TaskBoard_RemoveConfirm">Удалить задачу «{0}»?</sys:String>
    <sys:String x:Key="str_TaskBoard_RemoveConfirmTitle">Удаление задачи</sys:String>

    <!-- Сжатие контекста (T-000133) -->
    <sys:String x:Key="str_CompactContext">Сжать контекст</sys:String>
    <sys:String x:Key="str_CompactContextHint">Свернуть старую историю диалога в сводку — не дожидаясь автоматического сжатия. Сообщения останутся на месте. Это платный вызов AI.</sys:String>
    <sys:String x:Key="str_ContextCompactedFmt">Контекст сжат: {0:N0} → ~{1:N0} токенов</sys:String>
    <sys:String x:Key="str_ContextCompacted">Контекст сжат</sys:String>
    <sys:String x:Key="str_CompactBelowFloor">Сжимать пока нечего — контекст ещё не набрался.</sys:String>
</ResourceDictionary>
