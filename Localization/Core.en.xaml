<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Auth / LoginWindow (Phase 5a: user-key + X-Product-Key). Window title comes from IProductBranding.DisplayName, not a string resource. -->
    <sys:String x:Key="str_UserKeyLabel">User key</sys:String>
    <sys:String x:Key="str_UserKeyHint">Issued by an administrator.</sys:String>
    <sys:String x:Key="str_LoginButton">Sign in</sys:String>
    <sys:String x:Key="str_LoggingIn">Validating key...</sys:String>
    <sys:String x:Key="str_LoginError">Sign-in error</sys:String>
    <sys:String x:Key="str_InvalidKeyFormat">Enter a user key</sys:String>
    <sys:String x:Key="str_InvalidUserKey">Invalid or revoked user key</sys:String>
    <sys:String x:Key="str_UserDeleted">Account deleted. Contact your administrator.</sys:String>
    <sys:String x:Key="str_NoProductKey">Product key not configured (APP_PRODUCT_KEY in .env)</sys:String>
    <sys:String x:Key="str_TokenExpired">User key is invalid. Please sign in again.</sys:String>
    <sys:String x:Key="str_InsufficientBalance">Insufficient balance</sys:String>
    <sys:String x:Key="str_ChangeKeyConfirm">Change user key?</sys:String>
    <sys:String x:Key="str_NotConfigured">Not configured</sys:String>
    <sys:String x:Key="str_BalanceCoins">coins</sys:String>
    <sys:String x:Key="str_NoKeyHint">No key? Contact your project administrator.</sys:String>

    <!-- Core dialogs: ErrorExplainDialog -->
    <sys:String x:Key="str_ErrorExplainTitle">Explain Error</sys:String>
    <sys:String x:Key="str_ErrorCode">Error Code</sys:String>
    <sys:String x:Key="str_ErrorText">Error Text</sys:String>
    <sys:String x:Key="str_ModulePath">Module Path</sys:String>

    <!-- Core dialogs: CommandConfirmDialog -->
    <sys:String x:Key="str_CommandDescription">Command description</sys:String>
    <sys:String x:Key="str_ExecuteCommand">Execute</sys:String>
    <sys:String x:Key="str_SkipCommand">Skip</sys:String>
    <sys:String x:Key="str_AutoExecuteAll">Always execute</sys:String>

    <!-- Generic dialog buttons -->
    <sys:String x:Key="str_Send">Send</sys:String>
    <sys:String x:Key="str_Cancel">Cancel</sys:String>

    <!-- Chat skeleton (T-000046, v0.11.2). Shared keys for 1C and Universal chats. -->

    <!-- Composer -->
    <!-- The hint teaches the field: Enter sends, even though the box is multi-line.
         "Describe the task" only fits at the start — mid-dialog the task is already described. -->
    <sys:String x:Key="str_Chat_InputPlaceholder">Describe the task · Enter — send, Shift+Enter — new line</sys:String>
    <sys:String x:Key="str_Chat_InputPlaceholderOngoing">Enter — send, Shift+Enter — new line</sys:String>
    <sys:String x:Key="str_Chat_InputHint">Enter — send, Shift+Enter — newline</sys:String>
    <sys:String x:Key="str_Chat_SendButton">Send</sys:String>
    <sys:String x:Key="str_Chat_NewChat">New dialog</sys:String>
    <sys:String x:Key="str_Chat_Interrupt">Interrupt</sys:String>

    <!-- Assistant states -->
    <sys:String x:Key="str_Chat_Streaming">streaming</sys:String>
    <sys:String x:Key="str_Chat_Interrupted">interrupted</sys:String>
    <sys:String x:Key="str_Chat_Thinking">thinking…</sys:String>
    <sys:String x:Key="str_Chat_ToolContinue">Tool finished — processing the result…</sys:String>

    <!-- Reasoning block -->
    <sys:String x:Key="str_Chat_Reasoning">Reasoning</sys:String>

    <!-- Tool card -->
    <sys:String x:Key="str_Chat_ToolStatusSuccess">success</sys:String>
    <sys:String x:Key="str_Chat_ToolStatusFailure">failure</sys:String>
    <sys:String x:Key="str_Chat_ToolStatusPending">running</sys:String>

    <!-- Message actions -->
    <sys:String x:Key="str_Chat_ActionCopy">Copy</sys:String>
    <sys:String x:Key="str_Chat_ActionQuote">Quote</sys:String>
    <sys:String x:Key="str_Chat_ActionRetry">Retry</sys:String>
    <sys:String x:Key="str_Chat_ActionInfo">Turn info</sys:String>

    <!-- Info popup — key/value column -->
    <sys:String x:Key="str_Chat_InfoTitle">turn info</sys:String>
    <sys:String x:Key="str_Chat_InfoModel">model</sys:String>
    <sys:String x:Key="str_Chat_InfoProvider">provider</sys:String>
    <sys:String x:Key="str_Chat_InfoEffort">effort</sys:String>
    <sys:String x:Key="str_Chat_InfoReasoning">reasoning</sys:String>
    <sys:String x:Key="str_Chat_InfoPromptTokens">prompt</sys:String>
    <sys:String x:Key="str_Chat_InfoCompletionTokens">completion</sys:String>
    <sys:String x:Key="str_Chat_InfoTotalTokens">total</sys:String>
    <sys:String x:Key="str_Chat_InfoCost">cost</sys:String>
    <sys:String x:Key="str_Chat_InfoCostRub">in rub</sys:String>
    <sys:String x:Key="str_Chat_InfoCostUsd">in usd</sys:String>
    <sys:String x:Key="str_Chat_InfoTimeFirstChunk">first chunk</sys:String>
    <sys:String x:Key="str_Chat_InfoTimeTotal">total</sys:String>
    <sys:String x:Key="str_Chat_InfoMessageId">turn id</sys:String>
    <sys:String x:Key="str_Chat_InfoTime">time</sys:String>

    <!-- Task board (T-000080..T-000082, REQ-021) -->
    <!-- AI answer code block (T-000096) -->
    <sys:String x:Key="str_Chat_CopyCode">Copy</sys:String>
    <sys:String x:Key="str_Chat_CopyCodeHint">Copy the fragment to the clipboard</sys:String>
    <sys:String x:Key="str_Chat_ToSandbox">→ to sandbox</sys:String>
    <sys:String x:Key="str_Chat_ToSandboxHint">Put this fragment into the sandbox — from there it can be applied to the configurator window</sys:String>

    <!-- Context compaction (ANNOUNCE-005) -->
    <sys:String x:Key="str_Chat_ContextCompacted">Context compacted — earlier history is summarized below</sys:String>

    <sys:String x:Key="str_TaskBoard_Title">Task board</sys:String>
    <sys:String x:Key="str_TaskBoard_Pending">pending</sys:String>
    <sys:String x:Key="str_TaskBoard_InProgress">in progress</sys:String>
    <sys:String x:Key="str_TaskBoard_Done">done</sys:String>
    <sys:String x:Key="str_TaskBoard_Blocked">blocked</sys:String>
    <sys:String x:Key="str_TaskBoard_Cancelled">cancelled</sys:String>
    <sys:String x:Key="str_TaskBoard_Toggle">Collapse / expand the task board</sys:String>
    <sys:String x:Key="str_TaskBoard_UserChecked">Marked the task “{0}” as done.</sys:String>
    <sys:String x:Key="str_TaskBoard_UserUnchecked">Cleared the done mark on the task “{0}”.</sys:String>
    <sys:String x:Key="str_Tool_task_board_update">Task board</sys:String>
    <sys:String x:Key="str_TaskBoard_Add">+ Task</sys:String>
    <sys:String x:Key="str_TaskBoard_AddHint">Add a task manually</sys:String>
    <sys:String x:Key="str_TaskBoard_NewTask">New task</sys:String>
    <sys:String x:Key="str_TaskBoard_Empty">No tasks. Add one manually or ask the AI to draft a plan.</sys:String>
    <sys:String x:Key="str_TaskBoard_CycleHint">Change status: pending → in progress → done</sys:String>
    <sys:String x:Key="str_TaskBoard_RemoveHint">Remove the task</sys:String>
    <sys:String x:Key="str_TaskBoard_CurrentHint">Current task — its tracker id goes into the code markers</sys:String>
    <sys:String x:Key="str_TaskBoard_OurIdHint">Our task id within this dialog</sys:String>
    <sys:String x:Key="str_TaskBoard_TrackerHint">External tracker id (Jira etc.) — substituted into the marker as {task}</sys:String>
    <sys:String x:Key="str_TaskBoard_UserDoneHint">User mark: verified and accepted</sys:String>
    <sys:String x:Key="str_TaskBoard_DescriptionHint">Description</sys:String>
    <sys:String x:Key="str_TaskBoard_TrackerPlaceholder">e.g. JIRA-902</sys:String>
    <sys:String x:Key="str_TaskBoard_ColTask">TASK AND DESCRIPTION</sys:String>
    <sys:String x:Key="str_TaskBoard_ColOurId">OUR ID</sys:String>
    <sys:String x:Key="str_TaskBoard_ColTracker">TRACKER</sys:String>
    <sys:String x:Key="str_TaskBoard_ColUser">ACCEPTED</sys:String>
    <sys:String x:Key="str_TaskBoard_ColStatus">AI STATUS</sys:String>
    <sys:String x:Key="str_TaskBoard_ModeCurrent">current</sys:String>
    <sys:String x:Key="str_TaskBoard_ModeThree">3</sys:String>
    <sys:String x:Key="str_TaskBoard_ModeAll">all</sys:String>
    <sys:String x:Key="str_TaskBoard_DragHint">Drag to reorder tasks</sys:String>
    <sys:String x:Key="str_TaskBoard_SearchPlaceholder">Search by name, description, tracker…</sys:String>
    <sys:String x:Key="str_TaskBoard_SortManual">Sort: manual</sys:String>
    <sys:String x:Key="str_TaskBoard_SortStatus">Sort: by status</sys:String>
    <sys:String x:Key="str_TaskBoard_SortTracker">Sort: by tracker</sys:String>
    <sys:String x:Key="str_TaskBoard_RemoveConfirm">Remove the task “{0}”?</sys:String>
    <sys:String x:Key="str_TaskBoard_RemoveConfirmTitle">Remove task</sys:String>
</ResourceDictionary>
