<UserControl x:Class="SwanCode.Core.Chat.Views.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:SwanCode.Core.Chat.Views"
             xmlns:helpers="clr-namespace:SwanCode.Core.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="720"
             Background="{DynamicResource PrimaryBackground}">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <helpers:InvertBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <helpers:EmptyStringToVisibilityConverter x:Key="EmptyToVis"/>
        <helpers:CollectionToVisibilityConverter x:Key="CollToVis"/>
        <helpers:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <helpers:ToolDisplayNameConverter x:Key="ToolName"/>
        <helpers:ToolInputToVisibilityConverter x:Key="ToolInputToVis"/>

        <!-- Иконка-кнопка действия под сообщением (T-000074: только иконки) -->
        <Style x:Key="MsgActionButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryForeground}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ================= USER ================= -->
        <DataTemplate x:Key="UserTemplate">
            <Border HorizontalAlignment="Right"
                    MaxWidth="520"
                    Background="{DynamicResource UserBubbleBackground}"
                    BorderBrush="{DynamicResource UserBubbleBorder}"
                    BorderThickness="1"
                    CornerRadius="10,10,2,10"
                    Padding="12,8"
                    Margin="60,8,0,8">
                <!-- Read-only TextBox вместо TextBlock: текст своего сообщения
                     тоже выделяется и копируется (смок T-000074) -->
                <TextBox Text="{Binding Content, Mode=OneWay}"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="0"
                         Foreground="{DynamicResource PrimaryForeground}"
                         FontSize="13"/>
            </Border>
        </DataTemplate>

        <!-- ================= ASSISTANT ================= -->
        <DataTemplate x:Key="AssistantTemplate">
            <Grid Margin="0,8,60,8">
                <!-- ЯНТАРНЫЙ THINK-ЧИП (вариант A: пульс-точка) — пока ход в полёте -->
                <Border x:Name="ThinkChip"
                        HorizontalAlignment="Left"
                        Background="{DynamicResource ReasoningBackground}"
                        BorderBrush="{DynamicResource ReasoningBorder}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="13,7"
                        Visibility="{Binding IsThinking, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <!-- Пульс — только Opacity: анимация трансформов из Style-триггера
                             падает на замороженном экземпляре (крэш смока 06.07) -->
                        <Ellipse x:Name="PulseDot" Width="8" Height="8"
                                 Fill="{DynamicResource ReasoningForeground}"
                                 VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsThinking}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="PulseSb">
                                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="1" To="0.3" Duration="0:0:0.75"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="PulseSb"/>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding Content}"
                                   Margin="9,0,0,0"
                                   FontSize="12.5"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource ReasoningForeground}"/>
                    </StackPanel>
                </Border>

                <!-- ОБЫЧНОЕ СООБЩЕНИЕ -->
                <StackPanel Visibility="{Binding IsThinking, Converter={StaticResource InvBoolToVis}}">

                    <!-- Streaming / interrupted badges -->
                    <StackPanel Orientation="Horizontal">
                        <Border Padding="6,2" CornerRadius="3"
                                Background="{DynamicResource AccentColor}"
                                Opacity="0.85"
                                Visibility="{Binding IsStreaming, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{DynamicResource str_Chat_Streaming}"
                                       Foreground="{DynamicResource AccentOnFill}" FontSize="10"/>
                        </Border>
                        <Border Margin="8,0,0,0" Padding="6,2" CornerRadius="3"
                                Background="{DynamicResource ErrorBackground}"
                                Visibility="{Binding IsInterrupted, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{DynamicResource str_Chat_Interrupted}"
                                       Foreground="{DynamicResource ErrorColor}" FontSize="10"/>
                        </Border>
                    </StackPanel>

                    <!-- Рассуждение: янтарный блок с левой полосой (T-000074) -->
                    <Border BorderBrush="{DynamicResource ReasoningBorder}"
                            BorderThickness="3,0,0,0"
                            Background="{DynamicResource ReasoningBackground}"
                            CornerRadius="0,8,8,0"
                            Padding="12,7"
                            Margin="0,0,0,6"
                            Visibility="{Binding HasReasoning, Converter={StaticResource BoolToVis}}">
                        <Expander IsExpanded="False">
                            <Expander.Header>
                                <TextBlock Text="{DynamicResource str_Chat_Reasoning}"
                                           FontSize="11"
                                           Foreground="{DynamicResource ReasoningForeground}"/>
                            </Expander.Header>
                            <TextBlock Text="{Binding ReasoningText}"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0"
                                       Foreground="{DynamicResource ReasoningForeground}"
                                       FontSize="12"
                                       LineHeight="18"/>
                        </Expander>
                    </Border>

                    <!-- Карточки тулов: running / done / failed (T-000074, DLemma) -->
                    <!-- Без Visibility-байндинга: коллекция наполняется ПОСЛЕ добавления
                         сообщения (реюз thinking-bubble), CollToVis не пере-евалится.
                         Пустой ItemsControl не рендерит ничего. -->
                    <ItemsControl ItemsSource="{Binding ToolCalls}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="0,8,8,0"
                                        Padding="12,8"
                                        Margin="0,3">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource ToolCardBackground}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                            <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource SuccessColor}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsFailed}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource ErrorColor}"/>
                                                    <Setter Property="Background" Value="{DynamicResource ErrorBackground}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <DockPanel>
                                            <!-- Статус-иконка -->
                                            <Grid DockPanel.Dock="Left" Width="14" Height="14" Margin="0,0,9,0"
                                                  VerticalAlignment="Center">
                                                <!-- running: спиннер-дуга. Вращение стартует в code-behind
                                                     (Spinner_Loaded): анимация RenderTransform из XAML-стиля
                                                     бьётся о замороженный экземпляр (крэш смока 06.07) -->
                                                <Path Stroke="{DynamicResource AccentColor}"
                                                      StrokeThickness="2"
                                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                      Data="M 12 7 A 5 5 0 1 1 7 2"
                                                      RenderTransformOrigin="0.5,0.5"
                                                      Loaded="Spinner_Loaded"
                                                      Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"/>
                                                <!-- done: ✓ -->
                                                <TextBlock Text="✓" FontSize="12" FontWeight="Bold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource SuccessColor}"
                                                           Visibility="{Binding IsDone, Converter={StaticResource BoolToVis}}"/>
                                                <!-- failed: ✕ -->
                                                <TextBlock Text="✕" FontSize="12" FontWeight="Bold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource ErrorColor}"
                                                           Visibility="{Binding IsFailed, Converter={StaticResource BoolToVis}}"/>
                                            </Grid>

                                            <!-- Шеврон-разворачивалка входа (только шеврон, без слова) -->
                                            <ToggleButton x:Name="InputChevron" DockPanel.Dock="Right"
                                                          Background="Transparent" BorderThickness="0"
                                                          Cursor="Hand" Padding="4,0"
                                                          VerticalAlignment="Center"
                                                          Visibility="{Binding Input, Converter={StaticResource ToolInputToVis}}">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="Transparent" Padding="4,2">
                                                            <TextBlock x:Name="chev" Text="▸" FontSize="10"
                                                                       Foreground="{DynamicResource SecondaryForeground}"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="chev" Property="Text" Value="▾"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                            </ToggleButton>

                                            <!-- Локализованное имя; техимя — в ToolTip -->
                                            <TextBlock Text="{Binding Name, Converter={StaticResource ToolName}}"
                                                       ToolTip="{Binding Name}"
                                                       FontSize="12.5" FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource PrimaryForeground}"/>
                                        </DockPanel>

                                        <!-- JSON-вход (по шеврону) -->
                                        <Border Background="{DynamicResource CodeBackground}"
                                                BorderBrush="{DynamicResource CodeBorder}"
                                                BorderThickness="1"
                                                CornerRadius="5"
                                                Padding="9,6"
                                                Margin="0,7,0,0"
                                                Visibility="{Binding IsChecked, ElementName=InputChevron, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="{Binding Input}"
                                                       FontFamily="Consolas" FontSize="11"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource SecondaryForeground}"/>
                                        </Border>

                                        <!-- Итог тула: обычный — серым, ошибка — красным -->
                                        <TextBlock Text="{Binding ResultMessage}"
                                                   FontSize="12" TextWrapping="Wrap"
                                                   Margin="0,6,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource SecondaryForeground}"/>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasResultMessage}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsFailed}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource ErrorColor}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Пузырь ответа модели (смок T-000074: выделить фоном, как в мокапе):
                         markdown-контент + кнопки-иконки. Tool-раунды без текста — без пузыря. -->
                    <Border Background="{DynamicResource AssistantBubbleBackground}"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1"
                            CornerRadius="10,10,10,2"
                            Padding="13,10"
                            Margin="0,3,0,0"
                            Visibility="{Binding Content, Converter={StaticResource EmptyToVis}, ConverterParameter=invert}">
                        <StackPanel>
                            <!-- Content: markdown-рендер (T-000103) -->
                            <!-- CodeBlockCommand: кнопка «→ в песочницу» на код-блоках (T-000096).
                                 У Universal команды нет — кнопки просто не рисуются. -->
                            <RichTextBox helpers:MarkdownBehavior.Markdown="{Binding Content}"
                                         helpers:MarkdownBehavior.CodeBlockCommand="{Binding DataContext.SendCodeToSandboxCommand,
                                                   RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                         IsReadOnly="True"
                                         IsReadOnlyCaretVisible="False"
                                         IsDocumentEnabled="True"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="0"
                                         VerticalScrollBarVisibility="Disabled"
                                         HorizontalScrollBarVisibility="Disabled"
                                         PreviewMouseWheel="MessageBody_PreviewMouseWheel"/>

                            <!-- Кнопки-иконки: Копировать (✓-фидбек) и Цитата -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,6,0,0">
                                <Button Style="{StaticResource MsgActionButton}"
                                        ToolTip="{DynamicResource str_Chat_ActionCopy}"
                                        Click="CopyMessage_Click"
                                        Margin="0,0,4,0">
                                    <Path Width="13" Height="13" Stretch="Uniform"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Data="M8 3h11a1 1 0 0 1 1 1v13h-2V5H8V3zM4 7h11a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V8a1 1 0 0 1 1-1zm1 2v10h9V9H5z"/>
                                </Button>
                                <Button Style="{StaticResource MsgActionButton}"
                                        ToolTip="{DynamicResource str_Chat_ActionQuote}"
                                        Click="QuoteMessage_Click">
                                    <Path Width="13" Height="13" Stretch="Uniform"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Data="M6.5 5C4 5 2 7.2 2 10c0 2.5 1.7 4.4 4 4.4-.3 1.9-1.5 3.3-3.4 4.1l.9 1.5c3.6-1.2 5.9-4.1 5.9-8C9.4 8 8.3 5 6.5 5zm11 0C15 5 13 7.2 13 10c0 2.5 1.7 4.4 4 4.4-.3 1.9-1.5 3.3-3.4 4.1l.9 1.5c3.6-1.2 5.9-4.1 5.9-8C20.4 8 19.3 5 17.5 5z"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Чип аналитики цепочки: DisplayName модели + «i» с 2-ярусным хинтом -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,6,0,0"
                                Visibility="{Binding HasChain, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding ModelName}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   Foreground="{DynamicResource SecondaryForeground}"/>
                        <Border Width="22" Height="22" CornerRadius="11"
                                Background="{DynamicResource SecondaryBackground}"
                                BorderBrush="{DynamicResource BorderColor}"
                                BorderThickness="1"
                                ToolTipService.InitialShowDelay="150"
                                ToolTipService.ShowDuration="60000">
                            <TextBlock Text="i" FontFamily="Georgia" FontStyle="Italic" FontWeight="SemiBold"
                                       FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SecondaryForeground}"/>
                            <Border.ToolTip>
                                <!-- Вверх и влево от чипа (смок): Top + сдвиг так, чтобы
                                     правый край хинта лёг к чипу, а не уходил за окно -->
                                <ToolTip Background="{DynamicResource PopupBackground}"
                                         BorderBrush="{DynamicResource PopupBorder}"
                                         Foreground="{DynamicResource PrimaryForeground}"
                                         Placement="Top"
                                         HorizontalOffset="-205"
                                         Padding="0">
                                    <StackPanel Width="222" Margin="0,6">
                                        <TextBlock Text="{DynamicResource str_ChainTokens}"
                                                   FontSize="10.5" FontWeight="SemiBold" Margin="13,2,13,4"
                                                   Foreground="{DynamicResource AccentColor}"/>
                                        <Separator Margin="0,0,0,3"/>
                                        <DockPanel Margin="13,2"><TextBlock Text="{DynamicResource str_ChainPrompt}" Foreground="{DynamicResource SecondaryForeground}" FontSize="12"/><TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right" Text="{Binding Chain.PromptTokens, StringFormat={}{0:N0}}" FontSize="12"/></DockPanel>
                                        <DockPanel Margin="13,2"><TextBlock Text="{DynamicResource str_ChainCompletion}" Foreground="{DynamicResource SecondaryForeground}" FontSize="12"/><TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right" Text="{Binding Chain.CompletionTokens, StringFormat={}{0:N0}}" FontSize="12"/></DockPanel>
                                        <DockPanel Margin="13,2"><TextBlock Text="{DynamicResource str_ChainTotal}" Foreground="{DynamicResource SecondaryForeground}" FontSize="12"/><TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right" Text="{Binding Chain.TotalTokens, StringFormat={}{0:N0}}" FontSize="12"/></DockPanel>
                                        <DockPanel Margin="13,2"><TextBlock Text="{DynamicResource str_ChainSpeed}" Foreground="{DynamicResource SecondaryForeground}" FontSize="12"/><TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right" Text="{Binding Chain.SpeedDisplay}" FontSize="12"/></DockPanel>
                                        <TextBlock Text="{DynamicResource str_ChainCost}"
                                                   FontSize="10.5" FontWeight="SemiBold" Margin="13,8,13,4"
                                                   Foreground="{DynamicResource AccentColor}"/>
                                        <Separator Margin="0,0,0,3"/>
                                        <DockPanel Margin="13,2" Visibility="{Binding Chain.HasCoins, Converter={StaticResource BoolToVis}}"><TextBlock Text="{DynamicResource str_ChainCoins}" Foreground="{DynamicResource SecondaryForeground}" FontSize="12"/><TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right" Text="{Binding Chain.CoinsDisplay}" FontSize="12"/></DockPanel>
                                        <DockPanel Margin="13,2"><TextBlock Text="{DynamicResource str_ChainWallTime}" Foreground="{DynamicResource SecondaryForeground}" FontSize="12"/><TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right" Text="{Binding Chain.WallDisplay}" FontSize="12"/></DockPanel>
                                    </StackPanel>
                                </ToolTip>
                            </Border.ToolTip>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- ================= TOOL USE (standalone) ================= -->
        <DataTemplate x:Key="ToolUseTemplate">
            <Border BorderBrush="{DynamicResource AccentColor}"
                    BorderThickness="3,0,0,0"
                    Background="{DynamicResource ToolCardBackground}"
                    CornerRadius="0,8,8,0"
                    Padding="12,7"
                    Margin="24,4,60,4">
                <TextBlock Text="{Binding Content}"
                           FontFamily="Consolas"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource PrimaryForeground}"/>
            </Border>
        </DataTemplate>

        <!-- ================= TOOL RESULT (standalone) ================= -->
        <DataTemplate x:Key="ToolResultTemplate">
            <Border BorderBrush="{DynamicResource ToolCardBorder}"
                    BorderThickness="3,0,0,0"
                    Background="{DynamicResource ToolCardBackground}"
                    CornerRadius="0,8,8,0"
                    Padding="12,7"
                    Margin="24,4,60,4">
                <TextBlock Text="{Binding Content}"
                           FontFamily="Consolas"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource SecondaryForeground}"/>
            </Border>
        </DataTemplate>

        <!-- ================= DEBUG ================= -->
        <DataTemplate x:Key="DebugTemplate">
            <Border Background="{DynamicResource TertiaryBackground}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    Padding="8,6"
                    Margin="0,4"
                    Opacity="0.7">
                <TextBlock Text="{Binding Content}"
                           FontFamily="Consolas"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource SecondaryForeground}"/>
            </Border>
        </DataTemplate>

        <!-- ================= CHECKPOINT (ANNOUNCE-005) =================
             Сервер сжал старую историю в rolling-summary. Не реплика — разделитель:
             показываем, ГДЕ свёрнут контекст, и даём прочитать сводку. -->
        <DataTemplate x:Key="CheckpointTemplate">
            <Border Background="{DynamicResource TertiaryBackground}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12,8"
                    Margin="24,10,24,10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="⇲" FontSize="13" Margin="0,0,7,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryForeground}"/>
                        <TextBlock Text="{DynamicResource str_Chat_ContextCompacted}"
                                   FontSize="11" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryForeground}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Content}"
                               FontSize="11" TextWrapping="Wrap" Opacity="0.85"
                               Foreground="{DynamicResource SecondaryForeground}"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ================= SELECTOR ================= -->
        <views:MessageTemplateSelector x:Key="MessageSelector"
                                        UserTemplate="{StaticResource UserTemplate}"
                                        AssistantTemplate="{StaticResource AssistantTemplate}"
                                        ToolUseTemplate="{StaticResource ToolUseTemplate}"
                                        ToolResultTemplate="{StaticResource ToolResultTemplate}"
                                        DebugTemplate="{StaticResource DebugTemplate}"
                                        CheckpointTemplate="{StaticResource CheckpointTemplate}"/>
    </UserControl.Resources>

    <!-- Композер вынесен в ChatInputBar (T-000074): ChatView = только лента -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Доска задач (T-000082): липкая над тредом. Видна всегда — ею можно управлять
             руками, без AI (схлопывается в одну строку заголовка). -->
        <views:TaskBoardView Grid.Row="0" Margin="16,12,16,0"/>

        <ScrollViewer x:Name="ThreadScroll" Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="16,12,16,0">
            <ItemsControl ItemsSource="{Binding Messages}"
                          ItemTemplateSelector="{StaticResource MessageSelector}"/>
        </ScrollViewer>

        <!-- Welcome-экран первого запуска (T-000074): виден пока нет сообщений -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    MaxWidth="420" IsHitTestVisible="False">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Messages.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <!-- Брендовый знак: мятное кольцо с точкой (перекликается с кружком контекста) -->
            <Grid Width="56" Height="56" Margin="0,0,0,18" HorizontalAlignment="Center">
                <Ellipse Stroke="{DynamicResource AccentColor}" StrokeThickness="4" Opacity="0.9"/>
                <Ellipse Width="12" Height="12" Fill="{DynamicResource AccentColor}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
            <TextBlock Text="{DynamicResource str_Welcome_Title}"
                       FontSize="19" FontWeight="SemiBold"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       Foreground="{DynamicResource PrimaryForeground}"/>
            <TextBlock Text="{DynamicResource str_Welcome_Sub}"
                       FontSize="12.5" Margin="0,8,0,16" LineHeight="19"
                       HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                       Foreground="{DynamicResource SecondaryForeground}"/>
            <StackPanel HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,3">
                    <TextBlock Text="•" Foreground="{DynamicResource AccentColor}" FontWeight="Bold" Margin="0,0,8,0"/>
                    <TextBlock Text="{DynamicResource str_Welcome_Hint1}" FontSize="12" TextWrapping="Wrap"
                               Foreground="{DynamicResource SecondaryForeground}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,3">
                    <TextBlock Text="•" Foreground="{DynamicResource AccentColor}" FontWeight="Bold" Margin="0,0,8,0"/>
                    <TextBlock Text="{DynamicResource str_Welcome_Hint2}" FontSize="12" TextWrapping="Wrap"
                               Foreground="{DynamicResource SecondaryForeground}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,3">
