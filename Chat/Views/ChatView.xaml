<UserControl x:Class="SwanCode.Core.Chat.Views.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:SwanCode.Core.Chat.Views"
             xmlns:helpers="clr-namespace:SwanCode.Core.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="720"
             Background="{DynamicResource PrimaryBackground}">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <helpers:EmptyStringToVisibilityConverter x:Key="EmptyToVis"/>
        <helpers:CollectionToVisibilityConverter x:Key="CollToVis"/>
        <helpers:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>

        <!-- ================= USER ================= -->
        <DataTemplate x:Key="UserTemplate">
            <Border HorizontalAlignment="Right"
                    MaxWidth="520"
                    Background="{DynamicResource UserBubbleBackground}"
                    CornerRadius="10,10,2,10"
                    Padding="12,8"
                    Margin="60,8,0,8">
                <TextBlock Text="{Binding Content}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource PrimaryForeground}"
                           FontSize="13"/>
            </Border>
        </DataTemplate>

        <!-- ================= ASSISTANT ================= -->
        <DataTemplate x:Key="AssistantTemplate">
            <StackPanel Margin="0,10,60,10">

                <!-- Header: streaming/interrupted badges only (avatar-буква убрана — переработается в v0.12.0 брендовом ревью). Каждый badge сам коллапсится, StackPanel сожмётся. -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                    <Border Margin="0,0,0,0"
                            Padding="6,2"
                            CornerRadius="3"
                            Background="{DynamicResource AccentColor}"
                            Opacity="0.85"
                            Visibility="{Binding IsStreaming, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{DynamicResource str_Chat_Streaming}"
                                   Foreground="White"
                                   FontSize="10"/>
                    </Border>
                    <Border Margin="8,0,0,0"
                            Padding="6,2"
                            CornerRadius="3"
                            Background="#8B3A3A"
                            Visibility="{Binding IsInterrupted, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{DynamicResource str_Chat_Interrupted}"
                                   Foreground="White"
                                   FontSize="10"/>
                    </Border>
                </StackPanel>

                <!-- Reasoning expander -->
                <Expander Margin="0,0,0,6"
                          IsExpanded="False"
                          Visibility="{Binding HasReasoning, Converter={StaticResource BoolToVis}}">
                    <Expander.Header>
                        <TextBlock Text="{DynamicResource str_Chat_Reasoning}"
                                   FontSize="11"
                                   Foreground="{DynamicResource SecondaryForeground}"/>
                    </Expander.Header>
                    <Border Background="{DynamicResource SecondaryBackground}"
                            CornerRadius="4"
                            Padding="10,8"
                            Margin="4,4,0,0">
                        <TextBlock Text="{Binding ReasoningText}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource PrimaryForeground}"
                                   FontSize="12"
                                   LineHeight="18"/>
                    </Border>
                </Expander>

                <!-- Content: markdown-рендер, текст выделяется и копируется (T-000103).
                     PreviewMouseWheel пробрасывается родительскому ScrollViewer в code-behind. -->
                <RichTextBox helpers:MarkdownBehavior.Markdown="{Binding Content}"
                             IsReadOnly="True"
                             IsReadOnlyCaretVisible="False"
                             IsDocumentEnabled="True"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0"
                             Margin="0,0,0,6"
                             VerticalScrollBarVisibility="Disabled"
                             HorizontalScrollBarVisibility="Disabled"
                             PreviewMouseWheel="MessageBody_PreviewMouseWheel"
                             Visibility="{Binding Content, Converter={StaticResource EmptyToVis}, ConverterParameter=invert}"/>

                <!-- Tool uses -->
                <ItemsControl ItemsSource="{Binding ToolUses}"
                              Margin="0,0,0,6"
                              Visibility="{Binding ToolUses, Converter={StaticResource CollToVis}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Expander Margin="0,2">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔧 "
                                                   Foreground="{DynamicResource SecondaryForeground}"
                                                   FontSize="12"/>
                                        <TextBlock Text="{Binding Name}"
                                                   FontFamily="Consolas"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource AccentColor}"/>
                                        <TextBlock Text=" · "
                                                   Foreground="{DynamicResource SecondaryForeground}"
                                                   FontSize="12"/>
                                        <TextBlock Text="{Binding Input}"
                                                   FontFamily="Consolas"
                                                   FontSize="11"
                                                   MaxWidth="440"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource SecondaryForeground}"/>
                                    </StackPanel>
                                </Expander.Header>
                                <Border Background="{DynamicResource SecondaryBackground}"
                                        CornerRadius="4"
                                        Padding="10,8"
                                        Margin="20,4,0,0">
                                    <TextBlock Text="{Binding Input}"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource PrimaryForeground}"/>
                                </Border>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Tool results -->
                <ItemsControl ItemsSource="{Binding ToolResults}"
                              Margin="0,0,0,6"
                              Visibility="{Binding ToolResults, Converter={StaticResource CollToVis}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{DynamicResource BorderColor}"
                                    BorderThickness="0,0,0,1"
                                    Padding="6,4"
                                    Margin="0,2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="↳ "
                                               Foreground="{DynamicResource SecondaryForeground}"
                                               FontSize="12"/>
                                    <TextBlock Text="{Binding Name}"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               Foreground="{DynamicResource AccentColor}"/>
                                    <TextBlock Text=" · "
                                               Foreground="{DynamicResource SecondaryForeground}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding Status}"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               Foreground="{DynamicResource SecondaryForeground}"/>
                                    <TextBlock Text=" · "
                                               Foreground="{DynamicResource SecondaryForeground}"
                                               FontSize="11"
                                               Visibility="{Binding Message, Converter={StaticResource StringToVisibilityConverter}}"/>
                                    <TextBlock Text="{Binding Message}"
                                               FontSize="11"
                                               Foreground="{DynamicResource SecondaryForeground}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Actions row -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,4,0,0">
                    <Button Content="⧉"
                            ToolTip="{DynamicResource str_Chat_ActionCopy}"
                            Click="CopyMessage_Click"
                            Padding="6,3" Margin="0,0,2,0" FontSize="11"/>
                    <Button Content="❝"
                            ToolTip="{DynamicResource str_Chat_ActionQuote}"
                            Click="QuoteMessage_Click"
                            Padding="6,3" Margin="0,0,2,0" FontSize="11"/>
                    <Button Content="↻"
                            ToolTip="{DynamicResource str_Chat_ActionRetry}"
                            Click="RetryMessage_Click"
                            Padding="6,3" Margin="0,0,2,0" FontSize="11"/>
                    <Button Content="ⓘ"
                            ToolTip="{DynamicResource str_Chat_ActionInfo}"
                            Click="InfoMessage_Click"
                            Padding="6,3" FontSize="11"
                            Foreground="{DynamicResource AccentColor}">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{DynamicResource str_Chat_InfoTitle}" IsEnabled="False"/>
                                <Separator/>
                                <MenuItem Header="{Binding ModelName, StringFormat={}model: {0}}"/>
                                <MenuItem Header="{Binding ProviderName, StringFormat={}provider: {0}}"
                                          Visibility="{Binding ProviderName, Converter={StaticResource StringToVisibilityConverter}}"/>
                                <MenuItem Header="{Binding ReasoningEffort, StringFormat={}effort: {0}}"
                                          Visibility="{Binding ReasoningEffort, Converter={StaticResource StringToVisibilityConverter}}"/>
                                <Separator/>
                                <MenuItem Header="{Binding PromptTokens, StringFormat={}prompt: {0}}"/>
                                <MenuItem Header="{Binding CompletionTokens, StringFormat={}completion: {0}}"/>
                                <MenuItem Header="{Binding TotalTokens, StringFormat={}total: {0}}"/>
                                <Separator Visibility="{Binding HasBilling, Converter={StaticResource BoolToVis}}"/>
                                <MenuItem Header="{Binding CostCoins, StringFormat={}coins: {0:F2}}"
                                          Visibility="{Binding HasBilling, Converter={StaticResource BoolToVis}}"/>
                                <MenuItem Header="{Binding CostRub, StringFormat={}rub: {0:F2}}"
                                          Visibility="{Binding CostRub, Converter={StaticResource BoolToVis}}"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <!-- ================= TOOL USE (standalone) ================= -->
        <DataTemplate x:Key="ToolUseTemplate">
            <Border BorderBrush="{DynamicResource AccentColor}"
                    BorderThickness="2,0,0,0"
                    Background="{DynamicResource SecondaryBackground}"
                    Padding="10,6"
                    Margin="24,4,60,4">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔧 "
                               Foreground="{DynamicResource SecondaryForeground}"/>
                    <TextBlock Text="{Binding Content}"
                               FontFamily="Consolas"
                               FontSize="12"
                               Foreground="{DynamicResource AccentColor}"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ================= TOOL RESULT (standalone) ================= -->
        <DataTemplate x:Key="ToolResultTemplate">
            <Border BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="2,0,0,0"
                    Background="{DynamicResource SecondaryBackground}"
                    Padding="10,6"
                    Margin="24,4,60,4">
                <TextBlock Text="{Binding Content}"
                           FontFamily="Consolas"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource SecondaryForeground}"/>
            </Border>
        </DataTemplate>

        <!-- ================= DEBUG ================= -->
        <DataTemplate x:Key="DebugTemplate">
            <Border Background="{DynamicResource TertiaryBackground}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    Padding="8,6"
                    Margin="0,4"
                    Opacity="0.7">
                <TextBlock Text="{Binding Content}"
                           FontFamily="Consolas"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource SecondaryForeground}"/>
            </Border>
        </DataTemplate>

        <!-- ================= SELECTOR ================= -->
        <views:MessageTemplateSelector x:Key="MessageSelector"
                                        UserTemplate="{StaticResource UserTemplate}"
                                        AssistantTemplate="{StaticResource AssistantTemplate}"
                                        ToolUseTemplate="{StaticResource ToolUseTemplate}"
                                        ToolResultTemplate="{StaticResource ToolResultTemplate}"
                                        DebugTemplate="{StaticResource DebugTemplate}"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Messages thread -->
        <ScrollViewer Grid.Row="0"
                      x:Name="ThreadScroll"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="16,12,16,0">
            <ItemsControl ItemsSource="{Binding Messages}"
                          ItemTemplateSelector="{StaticResource MessageSelector}"/>
        </ScrollViewer>

        <!-- Composer -->
        <Border Grid.Row="1"
                Background="{DynamicResource SecondaryBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,10,0">
                    <TextBox x:Name="InputTextBox"
                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="36"
                             MaxHeight="120"
                             VerticalScrollBarVisibility="Auto"
                             PreviewKeyDown="InputTextBox_PreviewKeyDown"/>
                    <TextBlock IsHitTestVisible="False"
                               Text="{DynamicResource str_Chat_InputPlaceholder}"
                               Foreground="{DynamicResource SecondaryForeground}"
                               Margin="8,7,0,0"
                               VerticalAlignment="Top"
                               Visibility="{Binding Text, ElementName=InputTextBox, Converter={StaticResource EmptyToVis}}"/>
                </Grid>

                <Button Grid.Column="1"
                        Content="{DynamicResource str_Chat_SendButton}"
                        Command="{Binding SendMessageCommand}"
                        Padding="16,6"
                        Background="{DynamicResource AccentColor}"
                        Foreground="White"
                        VerticalAlignment="Bottom"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
