<UserControl x:Class="SwanCode.Core.Chat.Views.ChatInputBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:helpers="clr-namespace:SwanCode.Core.Helpers"
             mc:Ignorable="d" d:DesignWidth="1000">
    <!--
      Строка ввода на всю ширину окна (T-000074, мокап 2026-07-06).
      Контракт DataContext (продуктовый MainViewModel):
        ActiveChat        : ChatViewModelBase (+ ContextFillPercent/ContextTokensDisplay у наследника)
        ProjectSettings   : Models / SelectedModel / ReasoningSelection / ContextLengthText
      Левая зона = ширина сайдбара (250): комбо модели над «Размышления», справа кружок контекста.
    -->
    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <helpers:InvertBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <helpers:EmptyStringToVisibilityConverter x:Key="EmptyToVis"/>
        <helpers:PercentToArcConverter x:Key="PercentToArc"/>
        <helpers:ContextZoneConverter x:Key="CtxZone"/>
        <helpers:ModelFitsContextConverter x:Key="ModelFits"/>
        <helpers:IsNullConverter x:Key="IsNullConv"/>
    </UserControl.Resources>

    <Border Background="{DynamicResource SecondaryBackground}"
            BorderBrush="{DynamicResource BorderColor}"
            BorderThickness="0,1,0,0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- ===== Левая зона: модель + размышления + кружок (граница сайдбара продолжается) ===== -->
            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="0,0,1,0"
                    Padding="10,8">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <!-- Комбо модели: DisplayName + окно; не влезающие — задизейблены -->
                        <ComboBox ItemsSource="{Binding ProjectSettings.Models}"
                                  SelectedItem="{Binding ProjectSettings.SelectedModel}"
                                  FontSize="12"
                                  ToolTip="{DynamicResource str_ModelComboHint}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <!-- В закрытом боксе — только имя (узкая зона); окно+цены —
                                         только в выпадашке (триггер: есть предок ComboBoxItem) -->
                                    <DockPanel x:Name="row">
                                        <StackPanel x:Name="meta" DockPanel.Dock="Right" Orientation="Horizontal"
                                                    Margin="12,0,0,0" VerticalAlignment="Center"
                                                    Visibility="Collapsed">
                                            <TextBlock Text="{Binding DisplayContext}" FontSize="10.5"
                                                       Foreground="{DynamicResource SecondaryForeground}"/>
                                            <TextBlock Text=" · " FontSize="10.5"
                                                       Foreground="{DynamicResource SecondaryForeground}"/>
                                            <TextBlock Text="{Binding DisplayPrice}" FontSize="10.5"
                                                       Foreground="{DynamicResource SecondaryForeground}"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
                                    </DockPanel>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Value="False">
                                            <DataTrigger.Binding>
                                                <Binding RelativeSource="{RelativeSource FindAncestor, AncestorType=ComboBoxItem}"
                                                         Converter="{StaticResource IsNullConv}"/>
                                            </DataTrigger.Binding>
                                            <Setter TargetName="meta" Property="Visibility" Value="Visible"/>
                                            <Setter TargetName="row" Property="MinWidth" Value="210"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                                    <Setter Property="IsEnabled">
                                        <Setter.Value>
                                            <MultiBinding Converter="{StaticResource ModelFits}">
                                                <Binding Path="ContextLength"/>
                                                <Binding Path="DataContext.ActiveChat.ContextTokens"
                                                         RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                            </MultiBinding>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.45"/>
                                            <Setter Property="ToolTip" Value="{DynamicResource str_ModelTooSmall}"/>
                                            <Setter Property="ToolTipService.ShowOnDisabled" Value="True"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>

                        <!-- Размышления: янтарный селектор уровня -->
                        <DockPanel Margin="0,6,0,0">
                            <TextBlock Text="{DynamicResource str_Reasoning}"
                                       FontSize="11" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SecondaryForeground}"/>
                            <ComboBox DockPanel.Dock="Right" HorizontalAlignment="Right"
                                      MinWidth="110" FontSize="11.5"
                                      Foreground="{DynamicResource ReasoningForeground}"
                                      SelectedValuePath="Tag"
                                      SelectedValue="{Binding ProjectSettings.ReasoningSelection}"
                                      ToolTip="{DynamicResource str_ReasoningEffortHelp}">
                                <ComboBoxItem Content="{DynamicResource str_ReasoningOff}" Tag="off"/>
                                <ComboBoxItem Content="{DynamicResource str_EffortMinimal}" Tag="minimal"/>
                                <ComboBoxItem Content="{DynamicResource str_EffortLow}" Tag="low"/>
                                <ComboBoxItem Content="{DynamicResource str_EffortMedium}" Tag="medium"/>
                                <ComboBoxItem Content="{DynamicResource str_EffortHigh}" Tag="high"/>
                            </ComboBox>
                        </DockPanel>
                    </StackPanel>

                    <!-- Кружок контекста: дуга = заполнение; мята → янтарь ≥70% → красный >90% -->
                    <Grid Grid.Column="1" Width="27" Height="27" Margin="10,0,0,0" VerticalAlignment="Center"
                          Background="Transparent"
                          ToolTipService.InitialShowDelay="150">
                        <!-- Трек — BorderColor: TertiaryBackground сливался с фоном строки ввода -->
                        <Ellipse Stroke="{DynamicResource BorderColor}" StrokeThickness="3.6"
                                 Width="24.6" Height="24.6" Opacity="0.7"/>
                        <Path StrokeThickness="3.6"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Data="{Binding ActiveChat.ContextFillPercent, Converter={StaticResource PercentToArc}}">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Stroke" Value="{DynamicResource AccentColor}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveChat.ContextFillPercent, Converter={StaticResource CtxZone}}" Value="warn">
                                            <Setter Property="Stroke" Value="{DynamicResource ReasoningForeground}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ActiveChat.ContextFillPercent, Converter={StaticResource CtxZone}}" Value="crit">
                                            <Setter Property="Stroke" Value="{DynamicResource ErrorColor}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                        <Grid.ToolTip>
                            <ToolTip Background="{DynamicResource PopupBackground}"
                                     BorderBrush="{DynamicResource PopupBorder}"
                                     Foreground="{DynamicResource PrimaryForeground}">
                                <StackPanel MinWidth="170" Margin="4">
                                    <DockPanel Margin="0,2"><TextBlock Text="{DynamicResource str_CtxTooltipUsed}" Foreground="{DynamicResource SecondaryForeground}" FontSize="12"/><TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right" Text="{Binding ActiveChat.ContextTokens, StringFormat={}{0:N0}}" FontSize="12" Margin="12,0,0,0"/></DockPanel>
                                    <DockPanel Margin="0,2"><TextBlock Text="{DynamicResource str_CtxTooltipWindow}" Foreground="{DynamicResource SecondaryForeground}" FontSize="12"/><TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right" Text="{Binding ProjectSettings.ContextLengthText}" FontSize="12" Margin="12,0,0,0"/></DockPanel>
                                    <!-- Итоговая строка — цветом зоны заполнения (мята/янтарь/красный) -->
                                    <DockPanel Margin="0,2">
                                        <DockPanel.Resources>
                                            <Style x:Key="ZoneText" TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ActiveChat.ContextFillPercent, Converter={StaticResource CtxZone}}" Value="warn">
                                                        <Setter Property="Foreground" Value="{DynamicResource ReasoningForeground}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ActiveChat.ContextFillPercent, Converter={StaticResource CtxZone}}" Value="crit">
                                                        <Setter Property="Foreground" Value="{DynamicResource ErrorColor}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DockPanel.Resources>
                                        <TextBlock Style="{StaticResource ZoneText}" Text="{DynamicResource str_CtxTooltipFill}"/>
                                        <TextBlock Style="{StaticResource ZoneText}" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                   Text="{Binding ActiveChat.ContextFillPercent, StringFormat={}{0:F0}%}"
                                                   FontWeight="SemiBold" Margin="12,0,0,0"/>
                                    </DockPanel>
                                </StackPanel>
                            </ToolTip>
                        </Grid.ToolTip>
                    </Grid>
                </Grid>
            </Border>

            <!-- ===== Поле сообщения (начинается ровно под чатом) ===== -->
            <Grid Grid.Column="1" Margin="12,10">
                <TextBox x:Name="InputTextBox"
                         Text="{Binding ActiveChat.InputText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="52"
                         MaxHeight="140"
                         VerticalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Center"
                         PreviewKeyDown="InputTextBox_PreviewKeyDown"/>
                <TextBlock IsHitTestVisible="False"
                           Text="{DynamicResource str_Chat_InputPlaceholder}"
                           Foreground="{DynamicResource SecondaryForeground}"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           Visibility="{Binding Text, ElementName=InputTextBox, Converter={StaticResource EmptyToVis}}"/>
            </Grid>

            <!-- ===== Кнопка ➤/■ (toggle по IsBusy) ===== -->
            <Grid Grid.Column="2" Margin="0,0,14,0" VerticalAlignment="Center">
                <!-- Отправить -->
                <Button x:Name="SendButton"
                        Width="46" Height="42"
                        Command="{Binding ActiveChat.SendMessageCommand}"
                        ToolTip="{DynamicResource str_Chat_SendButton}"
                        Cursor="Hand"
                        Visibility="{Binding ActiveChat.IsBusy, Converter={StaticResource InvBoolToVis}}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{DynamicResource AccentColor}" CornerRadius="8">
                                <Path Width="18" Height="18" Stretch="Uniform"
                                      Fill="{DynamicResource AccentOnFill}"
                                      Data="M2.4 21.6 22.8 12 2.4 2.4 2.4 9.9 17 12 2.4 14.1Z"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentHoverColor}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentPressedColor}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.45"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <!-- Прервать (во время хода) -->
                <Button Width="46" Height="42"
                        Command="{Binding ActiveChat.InterruptCommand}"
                        ToolTip="{DynamicResource str_Chat_Interrupt}"
                        Cursor="Hand"
                        Visibility="{Binding ActiveChat.IsBusy, Converter={StaticResource BoolToVis}}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent"
                                    BorderBrush="{DynamicResource ErrorColor}" BorderThickness="1.5"
                                    CornerRadius="8">
                                <Rectangle Width="13" Height="13" Fill="{DynamicResource ErrorColor}" RadiusX="2" RadiusY="2"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource ErrorBackground}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.45"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>
    </Border>
</UserControl>
